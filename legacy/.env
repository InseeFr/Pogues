VITE_API_URL=http://localhost:5000
VITE_ACTIVE_NAMESPACES='Components,Actions,Stores,Utils,Models'
VITE_TROMBI_URL=

# AUTH : Set for test purpose, you should override it before use
# When VITE_OIDC_ENABLED equals false we switch on mocked implem, so by default OIDC is ENABLED
VITE_OIDC_ENABLED=true
VITE_OIDC_ISSUER=http://localhost:8080
VITE_OIDC_CLIENT_ID=localhost
# oidc scopes used to retrieve roles and other jwt attribute (e.g. "profile,roles")
VITE_OIDC_SCOPES=profile,roles

# OPTIONAL

VITE_DEFAULT_USER_ID=
VITE_DEFAULT_USER_NAME=
VITE_DEFAULT_USER_STAMP=

# FEATURE FLAGS

# if enabled, will allow to display a recap in pairwise question form
VITE_ENABLE_PAIRING_RECAP=

VITE_LOG_LEVEL=DEBUG